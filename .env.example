# Copy this to .env and fill in your values.

# llama-server connection
LLAMA_SERVER_URL=http://localhost:8080/v1
LLAMA_PORT=8080

# Path to your GGUF model file
LLAMA_MODEL_PATH=/path/to/your/model.gguf

# Model name as reported by llama-server (run: curl localhost:8080/v1/models)
LLAMA_MODEL=local-model

# Context window size (tokens)
LLAMA_CTX_SIZE=8192

# GPU layers: -1 = all layers on GPU (Apple Silicon), 0 = CPU only
LLAMA_N_GPU_LAYERS=-1

# Set to true to skip confirmation prompts for shell/file write tools
UNSAFE_MODE=false

# Maximum tool-call iterations per agent turn
MAX_TOOL_ITERATIONS=20
